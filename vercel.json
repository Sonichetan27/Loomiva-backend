{
  "version": 2,
  "builds": [
    {
      "src": "src/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/server.js"
    }
  ],
  "env": {
    "NODE_OPTIONS": "--experimental-json-modules",
    "FRONTEND_URL": "https://loomive-frontend.vercel.app",
    "BACKEND_URL": "https://loomiva-backend.vercel.app"
  },
  "functions": {
    "src/server.js": {
      "maxDuration": 20
    }
  }
}
